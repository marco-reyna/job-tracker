{
  "manifest_version": 3,
  "name": "Job Tracker",
  "version": "1.0",
  "description": "Capture job applications with AI in one click",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Tracker"
  },
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["<all_urls>"]
}
